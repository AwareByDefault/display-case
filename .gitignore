# Dependencies
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# TypeScript / test output
*.tsbuildinfo
test-results/
playwright-report/
.tmp/

# Display Case codegen + bundle cache and local visual-regression baselines
.display-case/

# Visual-regression diff images: written next to a committed baseline on a local
# mismatch (e.g. running --visual off-platform). Never commit these.
*.diff.png

# Display Case published builds (`display-case publish` output)
dist-showcase/
dist/

# Generated GitHub wiki mirror (`bun run wiki:build`); CI regenerates + pushes it.
.wiki-build/

# Claude
.claude/settings.local.json
# Linked git worktrees live here (EnterWorktree / `git worktree add`). They are
# full checkouts with their own configs — ignoring them keeps tooling run from
# the main checkout from descending into the duplicate root configs.
.claude/worktrees/
